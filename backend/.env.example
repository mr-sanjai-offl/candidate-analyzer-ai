# ==============================================================================
# ApexGuidance AI — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.
# Architecture Bible Section 10: All secrets via environment variables only.
# ==============================================================================

# --- Application ---
APP_NAME=ApexGuidance AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database (Supabase PostgreSQL — Architecture Section 4) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/apexguidance
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis (Architecture Section 4) ---
REDIS_URL=redis://localhost:6379/0

# --- CORS (Production-safe defaults — Architecture Section 10) ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Logging ---
LOG_LEVEL=INFO

# --- Sentry (Architecture Section 4) ---
SENTRY_DSN=

# --- Security / JWT (Architecture Section 10) ---
JWT_SECRET_KEY=dev_secret_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
